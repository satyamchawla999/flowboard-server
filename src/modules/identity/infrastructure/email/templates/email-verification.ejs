<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Verify your FlowBoard email</title>
  </head>
  <body style="margin:0;background:#f8fafc;color:#1f2937;font-family:Inter,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f8fafc;padding:32px 16px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:560px;background:#ffffff;border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;">
            <tr>
              <td style="padding:28px 32px 18px;border-bottom:1px solid #e2e8f0;">
                <div style="font-size:14px;font-weight:700;color:#2563eb;letter-spacing:.02em;"><%= appName %></div>
                <h1 style="margin:18px 0 0;font-size:24px;line-height:1.25;color:#172033;">Verify your email</h1>
              </td>
            </tr>
            <tr>
              <td style="padding:28px 32px 34px;">
                <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#475569;">Hi <%= displayName %>,</p>
                <p style="margin:0 0 24px;font-size:15px;line-height:1.7;color:#475569;">Confirm this email address to finish securing your FlowBoard account. This verification link expires in <strong><%= expiresInHours %> hours</strong>.</p>
                <a href="<%= actionUrl %>" style="display:inline-block;background:#2563eb;color:#ffffff;text-decoration:none;font-size:14px;font-weight:700;padding:13px 18px;border-radius:8px;">Verify email</a>
                <p style="margin:28px 0 0;font-size:13px;line-height:1.7;color:#64748b;">If the button does not work, paste this link into your browser:</p>
                <p style="margin:8px 0 0;font-size:12px;line-height:1.6;word-break:break-all;color:#2563eb;"><%= actionUrl %></p>
                <p style="margin:24px 0 0;font-size:13px;line-height:1.7;color:#64748b;">If you did not create a FlowBoard account, you can ignore this email.</p>
              </td>
            </tr>
          </table>
          <p style="margin:18px 0 0;font-size:12px;line-height:1.6;color:#94a3b8;">© <%= currentYear %> <%= appName %>. Need help? Contact <%= supportEmail %>.</p>
        </td>
      </tr>
    </table>
  </body>
</html>
