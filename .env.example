# Application
NODE_ENV=development
PORT=4000
APP_NAME=FlowBoard
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowboard_dev
DB_USER=flowboard
DB_PASSWORD=flowboard_secret

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@flowboard.com
PGADMIN_DEFAULT_PASSWORD=admin123

# JWT
JWT_SECRET=change_me_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_in_production
JWT_REFRESH_EXPIRES_IN=30d

# GraphQL
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=true
GRAPHQL_INTROSPECTION=true

# Outbox local relay
OUTBOX_LOCAL_RELAY_ENABLED=true
OUTBOX_RELAY_INTERVAL_MS=1000
OUTBOX_RELAY_BATCH_SIZE=50
OUTBOX_RELAY_MAX_ATTEMPTS=10
OUTBOX_RELAY_LOCK_TTL_MS=30000
OUTBOX_RELAY_BASE_RETRY_DELAY_MS=1000
OUTBOX_RELAY_MAX_RETRY_DELAY_MS=60000

# Inbox idempotency
INBOX_LOCK_TTL_MS=30000

# RabbitMQ dispatch
RABBITMQ_DISPATCH_ENABLED=false
RABBITMQ_DSN=amqp://rabbitmq:5672
RABBITMQ_EXCHANGE=flowboard.events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_ROUTING_KEY_PREFIX=flowboard
RABBITMQ_QUEUE=flowboard.events
RABBITMQ_QUEUE_BINDING_KEY=flowboard.#
RABBITMQ_HANDLER_NAME=flowboard.local-event-relay
RABBITMQ_CONSUMER_PREFETCH=10
RABBITMQ_IMMEDIATE_RETRIES=1
RABBITMQ_MAX_DELIVERY_ATTEMPTS=5
RABBITMQ_RETRY_DELAY_MS=10000
RABBITMQ_RETRY_EXCHANGE=flowboard.events.retry
RABBITMQ_RETRY_QUEUE=flowboard.events.retry
RABBITMQ_RETRY_ROUTING_KEY=flowboard.retry
RABBITMQ_DEAD_LETTER_EXCHANGE=flowboard.events.dlx
RABBITMQ_DEAD_LETTER_QUEUE=flowboard.events.dlq
RABBITMQ_DEAD_LETTER_ROUTING_KEY=flowboard.dead
RABBITMQ_HEARTBEAT_SECONDS=30
RABBITMQ_CONNECTION_NAME=flowboard-outbox-publisher
RABBITMQ_CONSUMER_CONNECTION_NAME=flowboard-consumer
RABBITMQ_FORWARD_PORT=5672
RABBITMQ_MANAGEMENT_FORWARD_PORT=15672

# Mail
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_NAME=FlowBoard
MAIL_FROM_ADDRESS=no-reply@flowboard.local
