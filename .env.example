# Application
NODE_ENV=development
PORT=4000
APP_NAME=FlowBoard
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowboard_dev
DB_USER=flowboard
DB_PASSWORD=flowboard_secret

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@flowboard.com
PGADMIN_DEFAULT_PASSWORD=admin123

# JWT
JWT_SECRET=change_me_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_in_production
JWT_REFRESH_EXPIRES_IN=30d

# GraphQL
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=true
GRAPHQL_INTROSPECTION=true

# Mail
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_NAME=FlowBoard
MAIL_FROM_ADDRESS=no-reply@flowboard.local
