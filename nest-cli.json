{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "modules/identity/infrastructure/email/templates/**/*",
        "outDir": "dist"
      }
    ],
    "plugins": [
      {
        "name": "@nestjs/graphql",
        "options": {
          "typeFileNameSuffix": [".model.ts", ".input.ts", ".args.ts"],
          "introspectComments": true
        }
      }
    ]
  }
}
